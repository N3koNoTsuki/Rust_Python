$ ==============================================================================
$ FICHIER EDS D'EXEMPLE ANNOTE
$ Basé sur l'analyse de :
$   - Turck CDS3.eds         (adaptateur EIP standard, simple)
$   - Murrelektronik 55514   (module I/O mixte DIO + IO-Link + Safety)
$
$ Un fichier EDS (Electronic Data Sheet) décrit un équipement EtherNet/IP
$ à un outil de configuration (ex: Studio 5000, RSNetWorx).
$ Il liste les assemblées d'I/O, les connexions disponibles et les paramètres
$ configurables de l'appareil.
$
$ Syntaxe :  $ commence un commentaire
$            Les sections sont délimitées par [NomSection]
$            Chaque entrée se termine par un point-virgule
$ ==============================================================================

$ ==============================================================================
$ SECTION [File] : Métadonnées du fichier EDS lui-même
$ ==============================================================================
[File]
        DescText   = "Module I/O Exemple EIP - DIO4 + IOL2";   $ Nom affiché
        CreateDate = 04-14-2026;                                $ Date création
        CreateTime = 10:00:00;
        ModDate    = 04-14-2026;
        ModTime    = 10:00:00;
        Revision   = 1.0;                                       $ Version du fichier EDS
        HomeURL    = "www.exemple.com";

$ ==============================================================================
$ SECTION [Device] : Identité de l'équipement sur le réseau CIP
$ ==============================================================================
[Device]
        VendCode    = 999;                          $ Code fournisseur ODVA (unique, attribué par ODVA)
        VendName    = "Exemple Corp";               $ Nom du fournisseur
        ProdType    = 7;                            $ Type produit : 7 = Generic Device
                                                    $   12 = Communications Adapter  (ex: CDS3)
                                                    $   35 = Safety Discrete I/O     (ex: MVK)
        ProdTypeStr = "Generic Device";
        ProdCode    = 1001;                         $ Code produit propre au fournisseur
        MajRev      = 1;                            $ Révision majeure firmware
        MinRev      = 0;                            $ Révision mineure firmware
        ProdName    = "ExempleIO DIO4 IOL2";        $ Nom affiché dans l'outil de conf
        Catalog     = "EX-1001";
        Icon        = "device.ico";                 $ Icône (optionnel)

$ ==============================================================================
$ SECTION [Device Classification] : Protocoles supportés
$ ==============================================================================
[Device Classification]
        Class1 = EtherNetIP;    $ Obligatoire pour tout device EIP
        $ Class2 = Safety;      $ Décommenté si le device supporte CIP Safety
                                $ (comme le MVK Murrelektronik)

$ ==============================================================================
$ SECTION [ParamClass] : Obligatoire si le device a des paramètres de sécurité
$ Présent dans le MVK (Safety), absent dans le CDS3 (standard)
$ ==============================================================================
$ [ParamClass]
$       MaxInst = 1;
$       Descriptor = 0x0000;
$       CfgAssembly = 0;
$       SafetyCfgAssembly = 768;    $ Instance de l'assemblée de config Safety

$ ==============================================================================
$ SECTION [Params] : Paramètres configurables de l'appareil
$
$ Format d'un paramètre :
$   ParamN =
$       0,                      $ Réservé, toujours 0
$       LinkPathSize,"LinkPath",$ Chemin CIP vers l'attribut (optionnel)
$                               $ Ex: 6,"20 3D 24 01 30 07" = Class 0x3D, Inst 1, Attr 7
$       Descriptor,             $ 0x0000=Lecture/Écriture, 0x0010=Lecture seule
$       DataType,               $ 0xC1=BOOL, 0xC2=SINT, 0xC6=USINT, 0xC7=UINT,
$                               $            0xC8=UDINT, 0xD1=BYTE, 0xD2=WORD, 0xD3=DWORD
$       DataSizeBytes,          $ Taille en octets
$       "Nom",
$       "Unité",
$       "Description aide",
$       min, max, defaut,
$       ,,,,                    $ Scaling (mult, div, base, offset)
$       ,,,,                    $ Liens (mult, div, base, offset)
$       ;                       $ Décimales
$ ==============================================================================
[Params]

        $ --- Paramètre général : layout des données ---
        Param1 =
                0,
                ,,
                0x0000,         $ Lecture/Écriture
                0xC6,           $ USINT (1 octet non signé)
                1,
                "Digital Data Layout",
                "",
                "Contrôle le format de la structure de données I/O",
                0, 1, 0,
                ,,,,
                ,,,,
                ;
        Enum1 =
                0, "Port Based",    $ Les bits sont organisés par port
                1, "Pin Based";     $ Les bits sont organisés par broche

        $ --- Paramètre de filtre d'entrée ---
        Param2 =
                0,
                ,,
                0x0000,
                0xC6,           $ USINT
                1,
                "Input Filter Time",
                "ms",
                "Temps de filtre antirebond pour les entrées numériques",
                1, 15, 3,       $ min=1ms, max=15ms, défaut=3ms
                ,,,,
                ,,,,
                ;
        Enum2 =
                1,  "1",
                3,  "3",
                10, "10",
                15, "15";

        $ --- Paramètre de mode d'un port IO-Link ---
        Param3 =
                0,
                ,,
                0x0000,
                0xC6,           $ USINT
                1,
                "Mode Port X6",
                "",
                "Configure le fonctionnement du port X6",
                0, 3, 0,
                ,,,,
                ,,,,
                ;
        Enum3 =
                0, "Deactivated",
                1, "IO-Link Manual Configuration",
                2, "IO-Link Autostart",
                3, "Digital Input";

        $ --- Paramètre lecture seule : état d'une entrée numérique ---
        Param10 =
                0,
                6, "20 04 24 01 30 03",  $ Assembly Object, Instance 1, Attr 3
                0x0010,                  $ Lecture seule (0x0010)
                0xC1,                    $ BOOL
                1,
                "Input X0 Pin 4",
                "",
                "Valeur logique de l'entrée X0 broche 4",
                0, 1, 0,
                ,,,,
                ,,,,
                ;
        Enum10 =
                0, "OFF",
                1, "ON";

        $ --- Paramètre de sortie numérique ---
        Param20 =
                0,
                ,,
                0x0000,         $ Lecture/Écriture
                0xC1,           $ BOOL
                1,
                "Output X4 Pin 4",
                "",
                "Commande de la sortie X4 broche 4",
                0, 1, 0,
                ,,,,
                ,,,,
                ;
        Enum20 =
                0, "OFF",
                1, "ON";

        $ --- Paramètre RPI (Requested Packet Interval) ---
        Param100 =
                0,
                ,,
                0x0000,
                0xC8,           $ UDINT (4 octets)
                4,
                "RPI Value",
                "us",
                "Intervalle de rafraîchissement demandé en microsecondes",
                1000, 3200000, 10000,    $ min=1ms, max=3.2s, défaut=10ms
                ,,,,
                ,,,,
                ;

        $ --- Paramètre pour connexion Listen-Only ---
        Param101 =
                0,
                ,,
                0x0000,
                0xC6,
                1,
                "ListenOnly ConnPoint",
                "",
                "Point de connexion heartbeat pour Listen-Only",
                192, 192, 192,
                ,,,,
                ,,,,
                ;

$ ==============================================================================
$ SECTION [Groups] : Groupes de paramètres pour l'affichage dans l'outil
$ Format : GroupN = "Nom", NombreDeParams, Param1, Param2, ...;
$ ==============================================================================
[Groups]
        Group1 =
                "General Settings",
                2,
                1, 2;           $ Param1 et Param2

        Group2 =
                "Port X6 IO-Link",
                1,
                3;              $ Param3

        Group3 =
                "Monitoring Inputs",
                1,
                10;

$ ==============================================================================
$ SECTION [Assembly] : Définition des assemblées d'I/O
$
$ Une assemblée est un bloc de données échangé cycliquement entre le scanner
$ (ex: automate) et l'adaptateur (ce device).
$
$ Format :
$   AssemN =
$       "Nom affiché",
$       "Path CIP" ou vide,     $ Chemin optionnel (format hex) vers l'objet
$       TailleEnOctets,         $ Taille totale déclarée
$       0x0000,                 $ Flags (0x0000 = standard)
$       ,,                      $ Réservé
$       NbBits, ParamRef,       $ Champ de données : NbBits bits liés à ParamRef
$       NbBits, ;               $ Champ de données : bits de padding (sans Param)
$
$ Convention de nommage vue dans les fichiers réels :
$   Instance 100-199 : assemblées de données INPUT  (T->O, du device vers le PLC)
$   Instance 110-169 : assemblées de données OUTPUT (O->T, du PLC vers le device)
$   Instance 170     : assemblée de CONFIGURATION
$   Instance 768+    : assemblées SAFETY (CIP Safety uniquement)
$   Instance 1270+   : sous-assemblées de configuration Safety
$ ==============================================================================
[Assembly]
        Object_Name       = "Assembly Object";
        Object_Class_Code = 0x04;

        $ -------------------------------------------------------
        $ Assemblée INPUT simple : 2 octets d'entrées numériques
        $ -------------------------------------------------------
        Assem100 =
                "Digital Inputs",
                ,                   $ Pas de chemin explicite (optionnel)
                2,                  $ 2 octets = 16 bits
                0x0000,
                ,,
                8, Param10,         $ Octet 0 : entrées numériques (8 bits liés à Param10)
                8, ;                $ Octet 1 : réservé / padding

        $ -------------------------------------------------------
        $ Assemblée INPUT étendue : entrées + status IO-Link
        $ (2 octets IO-Link en plus, structure similaire MVK Assem102)
        $ -------------------------------------------------------
        Assem102 =
                "Digital Inputs + IO-Link 2 Byte",
                ,
                6,                  $ 6 octets au total
                0x0000,
                ,,
                16, Assem100,       $ 2 octets : on réutilise Assem100 (composition)
                8,  Param10,        $ 1 octet  : données IO-Link port X6 (byte 0)
                8,  Param10,        $ 1 octet  : données IO-Link port X6 (byte 1)
                8,  Param10,        $ 1 octet  : données IO-Link port X7 (byte 0)
                8,  Param10;        $ 1 octet  : données IO-Link port X7 (byte 1)

        $ -------------------------------------------------------
        $ Assemblée OUTPUT : 1 octet de sorties numériques
        $ -------------------------------------------------------
        Assem110 =
                "Digital Outputs",
                ,
                2,                  $ 2 octets
                0x0000,
                ,,
                8, Param20,         $ Octet 0 : sorties numériques
                8, ;                $ Octet 1 : réservé

        $ -------------------------------------------------------
        $ Assemblée OUTPUT étendue : sorties + données IO-Link
        $ -------------------------------------------------------
        Assem111 =
                "Digital Outputs + IO-Link 2 Byte",
                ,
                6,                  $ 6 octets
                0x0000,
                ,,
                16, Assem110,       $ 2 octets : sorties numériques (composition)
                8,  Param20,        $ 1 octet  : données IO-Link output port X6 (b0)
                8,  Param20,        $ 1 octet  : données IO-Link output port X6 (b1)
                8,  Param20,        $ 1 octet  : données IO-Link output port X7 (b0)
                8,  Param20;        $ 1 octet  : données IO-Link output port X7 (b1)

        $ -------------------------------------------------------
        $ Assemblée de CONFIGURATION
        $ Contient les paramètres envoyés une fois à la connexion (Forward Open)
        $ -------------------------------------------------------
        Assem170 =
                "Configuration",
                ,
                4,                  $ 4 octets
                0x0000,
                ,,
                8, Param1,          $ Digital Data Layout
                8, Param2,          $ Input Filter Time
                8, Param3,          $ Mode Port X6
                8, ;                $ Réservé

        $ -------------------------------------------------------
        $ [SAFETY] Assemblée Safety OUTPUT : commande sorties sûres
        $ (Présent uniquement sur devices CIP Safety comme le MVK)
        $ -------------------------------------------------------
        Assem768 =
                "Safety Outputs",
                ,
                1,                  $ 1 octet
                0x0000,
                ,,
                1, Param20,         $ Bit 0 : Output X3 Pin 4
                1, Param20,         $ Bit 1 : Output X3 Pin 2
                6, ;                $ Bits 2-7 : réservés

        $ -------------------------------------------------------
        $ [SAFETY] Assemblée Safety INPUT : retour état entrées sûres
        $ -------------------------------------------------------
        Assem770 =
                "Safety Inputs",
                ,
                3,                  $ 3 octets
                0x0000,
                ,,
                1, Param10,         $ Bit 0 : Input X0 Pin 4
                1, Param10,         $ Bit 1 : Input X0 Pin 2
                1, Param10,         $ Bit 2 : Input X1 Pin 4
                1, Param10,         $ Bit 3 : Input X1 Pin 2
                4, ,                $ Bits 4-7 : réservés
                1, Param10,         $ Bit 8 : Status Input X0 Pin 4 (0=Alarm, 1=OK)
                1, Param10,         $ Bit 9 : Status Input X0 Pin 2
                6, ;                $ Bits 10-23 : réservés

        $ -------------------------------------------------------
        $ [SAFETY] Assemblée de CONFIGURATION Safety
        $ Envoyée uniquement par un scanner Safety (ex: GuardLogix)
        $ -------------------------------------------------------
        Assem769 =
                "Safety Configuration",
                ,
                4,                  $ 4 octets
                0x0000,
                ,,
                8, Param1,          $ Param safety passivation behavior
                8, Param1,          $ Param safety reintegration behavior
                16,;                $ Réservé

$ ==============================================================================
$ SECTION [Connection Manager] : Connexions CIP disponibles
$
$ Chaque connexion définit comment le scanner peut se connecter au device.
$ Format simplifié :
$   ConnectionN =
$       TransportClassFlags,    $ Quelle classe CIP (T1=0x0001, T3=0x0002)
$                               $ + déclencheur (cyclic=bit16, COS=bit17)
$                               $ + type (exclusive-owner=bit26, input-only=bit25)
$       ConnectionCapabilities, $ Format fixe/variable, point-to-point/multicast, priorité
$       RPIoT,,AssemOutput,     $ O->T : RPI, taille, assemblée de sortie (PLC->Device)
$       RPItO,,AssemInput,      $ T->O : RPI, taille, assemblée d'entrée (Device->PLC)
$       ,,                      $ Config proxy : taille, format
$       ,AssemConfig,           $ Config target : taille, assemblée de config
$       "Nom de la connexion",
$       "Aide",
$       "Chemin CIP";           $ 20 04 24 <InstConfig> 2C <InstOutput> 2C <InstInput>
$
$ Types de connexion courants :
$   Exclusive Owner : le scanner prend le contrôle exclusif (lecture+écriture)
$   Input Only      : lecture seule (pas de sortie envoyée)
$   Listen Only     : écoute passive (nécessite un Exclusive Owner actif)
$   Safety Output   : connexion Safety vers sorties sûres
$   Safety Input    : connexion Safety depuis entrées sûres
$ ==============================================================================
[Connection Manager]
        Revision    = 1;
        Object_Name = "Connection Manager Object";
        Object_Class_Code = 0x06;
        MaxInst     = 1;
        Number_Of_Static_Instances     = 1;
        Max_Number_Of_Dynamic_Instances = 0;

        $ -------------------------------------------------------
        $ Connexion 1 : Exclusive Owner - DIO seul (cas le plus simple)
        $ Identique en structure au CDS3 Connection1 et au MVK Connection3 "E1-DIO"
        $ -------------------------------------------------------
        Connection1 =
                0x04010002,         $ Transport class 1 & 3, cyclic, exclusive-owner, server
                0x44640405,         $ Fixed O->T & T->O, point-to-point, scheduled priority
                Param100,,Assem110, $ O->T : RPI=Param100, taille auto, Assem110 (outputs)
                Param100,,Assem100, $ T->O : RPI=Param100, taille auto, Assem100 (inputs)
                ,,                  $ Pas de config proxy
                ,Assem170,          $ Config target : Assem170
                "E1 - DIO",
                "Connexion exclusive propriétaire, entrées/sorties numériques seules",
                "20 04 24 AA 2C 6E 2C 64";  $ Class 0x04, Inst 170 (0xAA), Out 110 (0x6E), In 100 (0x64)

        $ -------------------------------------------------------
        $ Connexion 2 : Exclusive Owner - DIO + IO-Link 2 octets
        $ (Comme MVK Connection5 "E3 - DIO, IO-Link 2 Byte")
        $ -------------------------------------------------------
        Connection2 =
                0x04010002,         $ Transport class 1 & 3, cyclic, exclusive-owner, server
                0x44640405,
                Param100,,Assem111, $ O->T : Assem111 (outputs + IOL output)
                Param100,,Assem102, $ T->O : Assem102 (inputs + IOL input)
                ,,
                ,Assem170,          $ Config target
                "E2 - DIO + IOL 2B",
                "Connexion exclusive propriétaire avec données IO-Link 2 octets",
                "20 04 24 AA 2C 6F 2C 66";  $ Out=111(0x6F), In=102(0x66)

        $ -------------------------------------------------------
        $ Connexion 3 : Input Only
        $ Le scanner lit les entrées sans envoyer de sorties
        $ (Comme CDS3 Connection2 "Input Only Connection")
        $ -------------------------------------------------------
        Connection3 =
                0x02010002,         $ Transport class 1 & 3, cyclic, input-only, server
                0x44640305,         $ Fixed T->O, O->T=NULL, multicast ou p2p
                ,0,,                $ O->T : taille 0 (pas de sortie)
                Param100,,Assem100, $ T->O : inputs
                ,,
                ,,                  $ Pas de config pour input-only
                "Input Only",
                "Connexion lecture seule, pas de sorties envoyées",
                "20 04 24 01 2C FE 2C 64";  $ ConnPoint 0xFE = réservé input-only

        $ -------------------------------------------------------
        $ Connexion 4 : Listen Only
        $ Écoute passive : nécessite qu'une connexion Exclusive Owner soit active
        $ (Comme CDS3 Connection3 "Listen Only Connection")
        $ -------------------------------------------------------
        Connection4 =
                0x01010002,         $ Transport class 1 & 3, cyclic, listen-only, server
                0x44640305,
                ,0,,                $ O->T : taille 0
                Param100,,Assem100, $ T->O : inputs
                ,,
                ,,
                "Listen Only",
                "Écoute passive, dépend d'une connexion Exclusive Owner active",
                "20 04 24 01 2C [Param101] 2C 64";  $ ConnPoint depuis Param101

        $ -------------------------------------------------------
        $ Connexion 5 : Safety Output (CIP Safety uniquement)
        $ Utilisé par un scanner Safety (GuardLogix) pour commander les sorties sûres
        $ (Comme MVK Connection1 "Safety Output")
        $ -------------------------------------------------------
        Connection5 =
                0x84040001,         $ Safety, classe 0, trigger application, exclusive-owner
                0x22445505,         $ Format Safety spécifique (time coordination)
                Param100,,Assem768, $ O->T : Assem768 (safety outputs)
                ,,,                 $ T->O : pas d'entrée sur cette connexion
                ,,                  $ Config proxy
                ,Assem769,          $ Config target Safety
                "Safety Output",
                "Connexion CIP Safety pour la commande des sorties sûres",
                "20 04 25 00 01 03 2D 00 00 03 2C C7";  $ Chemin Safety avec SCID

        $ -------------------------------------------------------
        $ Connexion 6 : Safety Input (CIP Safety uniquement)
        $ Utilisé par un scanner Safety pour lire les entrées sûres
        $ (Comme MVK Connection2 "Safety Input")
        $ -------------------------------------------------------
        Connection6 =
                0x02040001,         $ Safety, classe 0, trigger application, input-only
                0x22445505,
                ,,,                 $ O->T : pas de sortie
                Param100,,Assem770, $ T->O : Assem770 (safety inputs)
                ,,
                ,Assem769,          $ Config target Safety
                "Safety Input",
                "Connexion CIP Safety pour la lecture des entrées sûres",
                "20 04 25 00 01 03 2C C7 2D 00 02 03";  $ Chemin Safety

$ ==============================================================================
$ SECTION [Port] : Ports physiques de communication
$ ==============================================================================
[Port]
        Port1 =
                TCP,                    $ Type : TCP/IP
                "TCP/IP",               $ Nom affiché
                "20 F5 24 01",          $ Chemin vers l'objet TCP/IP Interface (classe 0xF5)
                1;                      $ Numéro de port interne

$ ==============================================================================
$ SECTION [Capacity] : Capacités de connexion de l'équipement
$ ==============================================================================
[Capacity]
        ConnOverhead         = 0.1;     $ Overhead par connexion (10%)
        MaxIOConnections     = 4;       $ Max connexions I/O (classe 1)
        MaxMsgConnections    = 8;       $ Max connexions message (classe 3)
        MaxConsumersPerMcast = 1;       $ Max consommateurs multicast
        TSpec1               = TxRx, 128, 100;  $ Spéc. trafic : 128 octets, 100us

$ ==============================================================================
$ SECTION [TCP/IP Interface Class] : Classe objet TCP/IP (obligatoire EIP)
$ ==============================================================================
[TCP/IP Interface Class]
        Revision                        = 4;
        MaxInst                         = 1;
        Number_Of_Static_Instances      = 1;
        Max_Number_Of_Dynamic_Instances = 0;

$ ==============================================================================
$ SECTION [Ethernet Link Class] : Classe objet Ethernet Link
$ (Describe les interfaces Ethernet physiques du device)
$ ==============================================================================
[Ethernet Link Class]
        Revision                        = 4;
        MaxInst                         = 2;        $ 2 ports Ethernet (si switch intégré)
        Number_Of_Static_Instances      = 2;
        Max_Number_Of_Dynamic_Instances = 0;
        InterfaceLabel1                 = "Eth1";
        InterfaceLabel2                 = "Eth2";
        InterfaceType1                  = 2;        $ 2 = Twisted pair
        InterfaceType2                  = 2;

$ ==============================================================================
$ FIN DU FICHIER EDS D'EXEMPLE
$ ==============================================================================
$ RÉSUMÉ DES DIFFÉRENCES CLÉS entre les deux fichiers analysés :
$
$  Turck CDS3                  Murrelektronik MVK 55514
$  --------------------------  -----------------------------------------
$  ProdType = 12 (Comm Adapt)  ProdType = 35 (Safety Discrete I/O)
$  Pas de [ParamClass]         [ParamClass] avec SafetyCfgAssembly = 768
$  2 assemblées (In/Out 128W)  17 assemblées (DIO, IOL 2/4/8/32B, Safety)
$  4 connexions (EO/IO/LO)     17+ connexions (EO, LO, Safety)
$  Params simples (port speed) Params complexes (sécurité, IO-Link, timing)
$  Pas de Class2 = Safety       Class2 = Safety
$  MaxIOConnections = 3        MaxSafetyConnections = 2 + IO classiques
$ ==============================================================================
