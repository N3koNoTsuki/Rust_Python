$ EZ-EDS Version 3.36 Generated Electronic Data Sheet
$
$ ==============================================================================
$ DESCRIPTION DU PRODUIT : Nexio NX-8DI4DO-IOL
$ ==============================================================================
$
$ Le Nexio NX-8DI4DO-IOL est un module d'I/O compact sur rail DIN pour réseaux
$ EtherNet/IP. Il intègre dans un seul boîtier :
$
$   - 8 entrées numériques 24V DC (NPN/PNP), bornes à vis M3
$       . Groupe A : X0.0 à X0.3  (filtre antirebond configurable)
$       . Groupe B : X0.4 à X0.7  (filtre antirebond configurable)
$       . Indicateur LED vert par canal
$
$   - 4 sorties numériques PNP 24V DC, 0.5A max, bornes à vis M3
$       . Canaux Y0.0 à Y0.3
$       . Protection court-circuit électronique (fold-back)
$       . Comportement sur perte de connexion configurable par canal
$       . Indicateur LED vert (actif) / rouge (défaut) par canal
$
$   - 1 port IO-Link Master, classe A, M12 5 broches (port X1)
$       . Vitesse : COM1 (4.8 kbaud) / COM2 (38.4 kbaud) / COM3 (230.4 kbaud)
$       . Process Data jusqu'à 1 octet input / 1 octet output
$       . Validation de device et Data Storage optionnels
$       . Fallback Digital Input si IO-Link désactivé
$
$   - 1 port Ethernet M12 D-code femelle, 10/100 Mbit/s
$
$   - Alimentation séparée :
$       . US = 24V DC ±20%  (alimentation capteurs + logique)
$       . UA = 24V DC ±20%  (alimentation actionneurs)
$
$   - Gabarit : 50 x 100 x 75 mm, montage rail DIN EN60715
$
$ CONNEXIONS EIP DISPONIBLES :
$   E1 : Exclusive Owner - 8DI + 4DO
$   E2 : Exclusive Owner - 8DI + 4DO + IO-Link 1 octet
$   I1 : Input Only     - 8DI
$   I2 : Input Only     - 8DI + IO-Link 1 octet
$   L1 : Listen Only    - 8DI
$
$ Référence produit : NX-8DI4DO-IOL
$ VendCode : 1234  |  ProdCode : 2001
$ ==============================================================================

[File]
        DescText   = "Nexio NX-8DI4DO-IOL EtherNet/IP Module";
        CreateDate = 04-14-2026;
        CreateTime = 10:00:00;
        ModDate    = 04-14-2026;
        ModTime    = 10:00:00;
        Revision   = 1.0;
        HomeURL    = "www.nexio-automation.com";

[Device]
        VendCode    = 1234;
        VendName    = "Nexio Automation";
        ProdType    = 7;                    $ Generic Device
        ProdTypeStr = "Generic Device";
        ProdCode    = 2001;
        MajRev      = 1;
        MinRev      = 0;
        ProdName    = "NX-8DI4DO-IOL";
        Catalog     = "NX-8DI4DO-IOL";
        Icon        = "NexioIO.ico";

[Device Classification]
        Class1 = EtherNetIP;

